<% remaining_seats = group.remaining_seats + (reservation.persisted? ? reservation.people_count : 0) %>

<%= simple_form_for [event, group, reservation], html: { class: "box",
      data: {
        controller: "reservation-price",
        reservation_price_adult_price_value: event.adult_price,
        reservation_price_kid_price_value: event.kid_price,
        reservation_price_adult_guided_tour_price_value: event.adult_guided_tour_price,
        reservation_price_adult_label_value: t(".breakdown_adults"),
        reservation_price_guided_tour_label_value: t(".breakdown_guided_tour"),
        reservation_price_kid_label_value: t(".breakdown_kids"),
        reservation_price_persisted_value: reservation.persisted?
      } } do |f| %>
  <%= render "shared/errors", record: reservation %>

  <%= f.input :full_name %>

  <div class="notification is-light py-2 px-4">
    <%= t(".availability_hint", seats: remaining_seats) %>
  </div>

  <div class="columns">
    <div class="column">
      <%= f.input :adults_count, input_html: { min: 0,
            data: { reservation_price_target: "adultsCount", action: "input->reservation-price#recalculate" } } %>
    </div>
    <div class="column">
      <%= f.input :kids_count, input_html: { min: 0,
            data: { reservation_price_target: "kidsCount", action: "input->reservation-price#recalculate" } } %>
    </div>
    <div class="column">
      <%= f.input :guided_tour_only_adults, hint: t(".guided_tour_only_hint"), input_html: { min: 0,
            data: { reservation_price_target: "guidedTourOnlyAdults", action: "input->reservation-price#recalculate" } } %>
    </div>
  </div>

  <div class="field">
    <%= f.label :price_to_pay, class: "label" %>
    <div class="field has-addons">
      <div class="control is-expanded">
        <%= f.number_field :price_to_pay, step: 1, min: 0, class: "input",
              value: (format("%.2f", reservation.price_to_pay) if reservation.price_to_pay),
              data: { reservation_price_target: "priceToPay", action: "input->reservation-price#markOverridden" } %>
      </div>
      <div class="control">
        <button type="button" class="button is-light" data-action="reservation-price#useComputed">
          <%= t(".use_computed") %>
        </button>
      </div>
    </div>
    <%= f.error :price_to_pay, wrap_with: { tag: "p", class: "help is-danger" } %>
    <p class="help">
      <%= t(".suggested_price") %>
      <strong data-reservation-price-target="suggestedPrice">—</strong>
    </p>
    <p class="help has-text-grey" data-reservation-price-target="priceBreakdown"></p>
  </div>

  <%= f.input :status, collection: reservation_status_options,
        label_method: :first, value_method: :last, include_blank: false %>

  <div class="columns">
    <div class="column">
      <%= f.input :phone, as: :tel %>
    </div>
    <div class="column">
      <%= f.input :email %>
    </div>
    <div class="column">
      <%= f.input :tax_code %>
    </div>
  </div>

  <%= f.input :notes, input_html: { rows: 3 } %>

  <div class="field is-grouped">
    <div class="control">
      <%= f.submit t("actions.save"), class: "button is-primary" %>
    </div>
    <div class="control">
      <%= link_to t("actions.cancel"), event_group_path(event, group), class: "button is-light" %>
    </div>
  </div>
<% end %>
