<%= form_with model: event, class: "box" do |f| %>
  <%= render "shared/errors", record: event %>

  <div class="field">
    <%= f.label :title, class: "label" %>
    <div class="control">
      <%= f.text_field :title, class: "input" %>
    </div>
  </div>

  <div class="columns">
    <div class="column">
      <h2 class="label"><%= t(".adults") %></h2>
      <div class="field">
        <%= f.label :adult_price, class: "label is-small" %>
        <div class="control">
          <%= f.number_field :adult_price, step: :any, min: 0, class: "input" %>
        </div>
      </div>
      <div class="field">
        <%= f.label :adult_ticket_price, class: "label is-small" %>
        <div class="control">
          <%= f.number_field :adult_ticket_price, step: :any, min: 0, class: "input" %>
        </div>
      </div>
      <div class="field">
        <%= f.label :adult_guided_tour_price, class: "label is-small" %>
        <div class="control">
          <%= f.number_field :adult_guided_tour_price, step: :any, min: 0, class: "input" %>
        </div>
      </div>
    </div>
    <div class="column">
      <h2 class="label"><%= t(".kids") %></h2>
      <div class="field">
        <%= f.label :kid_price, class: "label is-small" %>
        <div class="control">
          <%= f.number_field :kid_price, step: :any, min: 0, class: "input" %>
        </div>
      </div>
      <div class="field">
        <%= f.label :kid_ticket_price, class: "label is-small" %>
        <div class="control">
          <%= f.number_field :kid_ticket_price, step: :any, min: 0, class: "input" %>
        </div>
      </div>
      <div class="field">
        <%= f.label :kid_guided_tour_price, class: "label is-small" %>
        <div class="control">
          <%= f.number_field :kid_guided_tour_price, step: :any, min: 0, class: "input" %>
        </div>
      </div>
    </div>
  </div>

  <div class="field">
    <%= f.label :max_group_size, class: "label" %>
    <div class="control">
      <%= f.number_field :max_group_size, min: 1, class: "input" %>
    </div>
  </div>

  <div class="field">
    <%= f.label :notes, class: "label" %>
    <div class="control">
      <%= f.text_area :notes, rows: 4, class: "textarea" %>
    </div>
  </div>

  <div class="field">
    <%= f.label :description, class: "label" %>
    <div class="control">
      <%= f.text_area :description, rows: 4, class: "textarea" %>
    </div>
    <p class="help"><%= t(".public_hint") %></p>
  </div>

  <div class="field">
    <%= f.label :image, class: "label" %>
    <% if event.image.attached? %>
      <%= image_tag event.image.variant(resize_to_limit: [200, 200]), class: "event-image-thumb mb-2" %>
    <% end %>
    <div class="control">
      <%= f.file_field :image, accept: "image/png,image/jpeg,image/webp,image/gif", class: "input" %>
    </div>
    <p class="help"><%= t(".public_hint") %></p>
  </div>

  <div class="field is-grouped">
    <div class="control">
      <%= f.submit t("actions.save"), class: "button is-primary" %>
    </div>
    <div class="control">
      <%= link_to t("actions.cancel"), events_path, class: "button is-light" %>
    </div>
  </div>
<% end %>
