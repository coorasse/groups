<% content_for :title, t(".title") %>
<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="level">
  <div class="level-left">
    <h1 class="title level-item"><%= t(".title") %></h1>
  </div>
  <div class="level-right">
    <%= link_to t(".new"), new_event_path, class: "button is-primary level-item" %>
  </div>
</div>

<% total_requested = @requested_counts.values.sum %>
<% if total_requested.positive? %>
  <div class="notification is-warning">
    <strong><%= t(".to_process_banner", count: total_requested) %></strong>
  </div>
<% end %>

<% if @events.any? %>
  <div class="columns is-multiline">
    <% @events.each do |event| %>
      <% requested_count = @requested_counts.fetch(event.id, 0) %>
      <div class="column is-half-tablet is-one-third-desktop">
        <div class="card event-card">
          <% if event.image.attached? %>
            <div class="card-image">
              <figure class="image is-16by9">
                <%= image_tag event.image.variant(resize_to_fill: [640, 360]), class: "has-ratio" %>
              </figure>
            </div>
          <% end %>
          <div class="card-content">
            <div class="is-flex is-justify-content-space-between is-align-items-flex-start mb-3">
              <h2 class="title is-5 mb-0">
                <%= link_to event.title, event, class: "event-card-link" %>
              </h2>
              <%= to_process_tag(requested_count) if requested_count.positive? %>
            </div>
            <div class="content is-small mb-0">
              <p class="mb-1">
                <strong><%= t(".adults") %>:</strong>
                <%= number_to_currency(event.adult_price) %>
                <span class="has-text-grey">· <%= t(".ticket") %> <%= number_to_currency(event.adult_ticket_price) %></span>
              </p>
              <p class="mb-1">
                <strong><%= t(".kids") %>:</strong>
                <%= number_to_currency(event.kid_price) %>
                <span class="has-text-grey">· <%= t(".ticket") %> <%= number_to_currency(event.kid_ticket_price) %></span>
              </p>
              <p class="mb-1">
                <strong><%= Event.human_attribute_name(:max_group_size) %>:</strong>
                <%= event.max_group_size %>
              </p>
              <p class="mb-1">
                <strong><%= t(".groups_count") %>:</strong>
                <%= event.groups.count %>
              </p>
            </div>
            <div class="buttons event-card-actions mb-0">
              <%= link_to t("actions.edit"), edit_event_path(event), class: "button is-small" %>
              <%= button_to t("actions.destroy"), event, method: :delete,
                    class: "button is-small is-danger is-light",
                    form: { data: { turbo_confirm: t("actions.confirm") } } %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="notification is-light">
    <%= t(".empty") %>
  </div>
<% end %>

<% if @requested_reservations.any? %>
  <h2 class="subtitle mt-5"><%= t(".pending_reservations") %></h2>
  <div class="table-container">
    <table class="table is-fullwidth is-hoverable">
      <thead>
        <tr>
          <th><%= Reservation.human_attribute_name(:full_name) %></th>
          <th><%= Event.model_name.human %></th>
          <th><%= t(".group_schedule") %></th>
          <th><%= t(".adults_short") %></th>
          <th><%= t(".kids_short") %></th>
          <th><%= Reservation.human_attribute_name(:price_to_pay) %></th>
          <th><%= Reservation.human_attribute_name(:status) %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @requested_reservations.each do |reservation| %>
          <% group = reservation.group %>
          <% event = group.event %>
          <tr id="<%= dom_id(reservation) %>">
            <td><%= link_to reservation.full_name, event_group_reservation_path(event, group, reservation) %></td>
            <td><%= link_to event.title, event_path(event) %></td>
            <td><%= link_to group_label(group), event_group_path(event, group) %></td>
            <td><%= reservation.adults_count %></td>
            <td><%= reservation.kids_count %></td>
            <td><%= number_to_currency(reservation.price_to_pay) %></td>
            <td>
              <%= form_with model: [event, group, reservation], data: { controller: "autosubmit" } do |f| %>
                <%= hidden_field_tag :inline, "1" %>
                <div class="select is-small">
                  <%= f.select :status, reservation_status_options, {}, data: { action: "change->autosubmit#submit" } %>
                </div>
              <% end %>
            </td>
            <td class="has-text-right">
              <%= link_to t("actions.edit"), edit_event_group_reservation_path(event, group, reservation), class: "button is-small" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
