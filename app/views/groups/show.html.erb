<% content_for :title, "#{@event.title} - #{group_label(@group)}" %>
<% content_for :head do %>
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
<% end %>

<p class="is-size-7 has-text-grey">
  <%= link_to t("events.index.title"), events_path %> ›
  <%= link_to @event.title, event_path(@event) %>
</p>

<div class="level">
  <div class="level-left">
    <h1 class="title level-item mb-0"><%= @event.title %> - <%= group_label(@group) %></h1>
    <div class="level-item"><%= group_status_tag(@group) %></div>
    <% if @group.needs_notification? %>
      <div class="level-item"><%= to_notify_tag(@group.reservations_to_notify.count) %></div>
    <% end %>
  </div>
  <div class="level-right">
    <%= link_to action_icon(:edit), edit_event_group_path(@event, @group), class: "button level-item",
          title: t("actions.edit"), "aria-label": t("actions.edit") %>
  </div>
</div>

<div class="level">
  <div class="level-left">
    <h2 class="subtitle level-item mb-0"><%= t(".reservations") %></h2>
  </div>
  <div class="level-right">
    <%= link_to t(".new_reservation"), new_event_group_reservation_path(@event, @group),
          class: "button is-primary level-item" %>
  </div>
</div>

<% if @reservations.any? %>
  <% notify_window = @group.within_notify_window? %>
  <div class="table-container" data-controller="highlight-row">
    <table class="table is-fullwidth is-hoverable">
      <thead>
        <tr>
          <% if notify_window %>
            <th class="has-text-centered"><%= t(".notified") %></th>
          <% end %>
          <th><%= Reservation.human_attribute_name(:full_name) %></th>
          <th><%= Reservation.human_attribute_name(:phone) %></th>
          <th><%= t(".adults_short") %></th>
          <th><%= t(".kids_short") %></th>
          <th><%= t(".guided_tour_only") %></th>
          <th><%= Reservation.human_attribute_name(:price_to_pay) %></th>
          <th><%= t(".price_difference") %></th>
          <th><%= Reservation.human_attribute_name(:status) %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @reservations.each do |reservation| %>
          <tr id="<%= dom_id(reservation) %>" class="<%= "has-text-grey" if reservation.cancelled? %>">
            <% if notify_window %>
              <td class="has-text-centered">
                <% if reservation.cancelled? %>
                  —
                <% else %>
                  <%= form_with model: [@event, @group, reservation], data: { controller: "autosubmit" },
                        class: "reservation-notified" do |f| %>
                    <%= hidden_field_tag :inline, "1" %>
                    <label class="checkbox" title="<%= t(".notified") %>">
                      <%= f.check_box :notified, data: { action: "change->autosubmit#submit" } %>
                    </label>
                  <% end %>
                <% end %>
              </td>
            <% end %>
            <td class="reservation-name">
              <%= link_to reservation.full_name, event_group_reservation_path(@event, @group, reservation) %>
              <%= render "reservations/notes", event: @event, group: @group, reservation: reservation %>
            </td>
            <td class="reservation-phone">
              <% if reservation.phone.present? %>
                <%= link_to reservation.phone, "tel:#{reservation.phone}" %>
              <% else %>
                —
              <% end %>
            </td>
            <td><%= render "reservations/inline_number", event: @event, group: @group, reservation: reservation, field: :adults_count, narrow: true %></td>
            <td><%= render "reservations/inline_number", event: @event, group: @group, reservation: reservation, field: :kids_count, narrow: true %></td>
            <td><%= reservation.guided_tour_only_adults %></td>
            <td><%= render "reservations/inline_number", event: @event, group: @group, reservation: reservation, field: :price_to_pay, step: "any" %></td>
            <td><%= price_difference_tag(reservation.price_difference) %></td>
            <td>
              <%= form_with model: [@event, @group, reservation], data: { controller: "autosubmit" } do |f| %>
                <%= hidden_field_tag :inline, "1" %>
                <div class="select is-small">
                  <%= f.select :status, reservation_status_options, {}, data: { action: "change->autosubmit#submit" } %>
                </div>
              <% end %>
            </td>
            <td class="has-text-right reservation-actions">
              <% if @event.message_template.present? %>
                <button type="button" class="button is-small"
                        data-controller="clipboard"
                        data-clipboard-text-value="<%= reservation_message(reservation) %>"
                        data-clipboard-copied-label-value="<%= t(".message_copied") %>"
                        data-action="clipboard#copy"
                        title="<%= t(".copy_message") %>" aria-label="<%= t(".copy_message") %>">
                  <%= action_icon(:copy) %>
                </button>
              <% end %>
              <%= link_to action_icon(:edit), edit_event_group_reservation_path(@event, @group, reservation), class: "button is-small",
                    title: t("actions.edit"), "aria-label": t("actions.edit") %>
              <%= button_to action_icon(:destroy), event_group_reservation_path(@event, @group, reservation), method: :delete,
                    class: "button is-small is-danger is-light",
                    title: t("actions.destroy"), "aria-label": t("actions.destroy"),
                    form: { data: { turbo_confirm: t("actions.confirm") } } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="notification is-light">
    <%= t(".no_reservations") %>
  </div>
<% end %>

<h2 class="subtitle mt-6"><%= t(".details") %></h2>

<div class="columns is-multiline">
  <%= stat_card(Group.human_attribute_name(:people_count)) do %>
    <%= @group.people_count %>
    <p class="is-size-7 has-text-grey has-text-weight-normal">
      <%= @group.adults_count %> <%= Group.human_attribute_name(:adults_count).downcase %>,
      <%= @group.kids_count %> <%= Group.human_attribute_name(:kids_count).downcase %>
    </p>
  <% end %>

  <%= stat_card(t(".available_seats")) do %>
    <%= seats_left_tag(@group) %>
    <p class="is-size-7 has-text-grey has-text-weight-normal"><%= t(".max_indicative", count: @group.effective_max_group_size) %></p>
    <p class="is-size-7 has-text-grey has-text-weight-normal"><%= t(".overbooking_allowance", count: @group.effective_max_overbooking) %></p>
  <% end %>

  <div class="column is-half">
    <%= card(title: t(".prices")) do %>
      <table class="table is-fullwidth mb-0">
        <tbody>
          <tr>
            <th><%= t(".computed_price") %></th>
            <td class="has-text-right"><%= number_to_currency(@group.computed_price) %></td>
          </tr>
          <tr>
            <th><%= t(".total_price") %></th>
            <td class="has-text-right"><%= number_to_currency(@group.total_price) %></td>
          </tr>
          <tr>
            <th><%= t(".price_difference") %></th>
            <td class="has-text-right"><%= price_difference_tag(@group.price_difference) %></td>
          </tr>
          <tr>
            <th><%= Group.human_attribute_name(:net_price) %></th>
            <td>
              <%= form_with model: [@event, @group], data: { controller: "autosubmit" },
                    class: "field is-flex is-justify-content-flex-end mb-0" do |f| %>
                <%= hidden_field_tag :inline, "1" %>
                <div class="control">
                  <%= f.number_field :net_price, step: :any, min: 0,
                        class: "input is-small has-text-right table-input", placeholder: number_to_currency(0),
                        data: { action: "change->autosubmit#submit" } %>
                </div>
              <% end %>
            </td>
          </tr>
        </tbody>
      </table>
    <% end %>
  </div>

  <%= stat_card(t(".reservations"), column_class: "is-half") do %>
    <div class="tags is-justify-content-center mb-0">
      <% %w[requested confirmed paid].each do |status| %>
        <%= reservation_status_count_tag(status, @group.people_count_for(status)) %>
      <% end %>
    </div>
  <% end %>

  <% if @group.notes.present? %>
    <div class="column is-full">
      <%= card(title: Group.human_attribute_name(:notes)) do %>
        <%= simple_format @group.notes %>
      <% end %>
    </div>
  <% end %>
</div>
